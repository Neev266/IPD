            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"optional-draft-id\",\n  \"title\": \"Draft Title\",\n  \"content\": \"Draft content here...\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/supabase/drafts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "supabase",
                "drafts"
              ]
            },
            "description": "Create or update a draft for the authenticated user (upsert). If a draft with the provided `id` already exists, it is updated with the new content. If no `id` is provided, a new draft is created. Returns the saved draft object."
          },
          "response": []
        },
        {
          "name": "Get Drafts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/supabase/drafts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "supabase",
                "drafts"
              ]
            },
            "description": "Load all drafts belonging to the authenticated user. Returns an array of draft objects sorted by last-modified date (most recent first). Each draft includes its ID, title, content, and timestamps."
          },
          "response": []
