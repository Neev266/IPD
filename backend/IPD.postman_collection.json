    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "The file to upload (PDF, DOCX, TXT, etc.)",
                  "value": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "upload"
              ]
            },
            "description": "Upload a file for the authenticated user. Send a multipart/form-data request with a single file field named `file`. Returns the stored file path/URL and metadata such as filename, size, and MIME type."
          },
          "response": []
        },
        {
          "name": "Parse Remote URL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com/document.pdf\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/upload/parse-url",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "upload",
                "parse-url"
              ]
            },
            "description": "Fetch and parse content from a remote URL. Provide a publicly accessible URL in the request body. The server downloads the resource, extracts its text content, and returns it for further processing."
          },
          "response": []
        }
      ],
      "description": "Endpoints for uploading files and parsing remote URLs. All routes require authentication."
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Get Documents",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/documents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents"
              ]
            },
            "description": "Retrieve all documents belonging to the authenticated user. Returns an array of document objects including metadata such as title, creation date, and file type."
          },
          "response": []
        },
        {
          "name": "Save Document",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Document\",\n  \"content\": \"Document text content here...\",\n  \"metadata\": {}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/documents/save",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "save"
              ]
            },
            "description": "Save a new document or update an existing one for the authenticated user. Provide the document title, content, and any optional metadata. If an `id` is included in the body, the existing document is updated; otherwise a new document is created."
          },
          "response": []
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"document-id-here\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/documents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents"
              ]
            },
            "description": "Delete a document belonging to the authenticated user. Provide the document ID in the request body. The document is permanently removed and cannot be recovered."
          },
          "response": []
        }
      ],
      "description": "CRUD operations for user documents. All routes are protected and operate on documents belonging to the authenticated user."
    },
    {
      "name": "Pipeline",
      "item": [
        {
          "name": "Ingest Document",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "The document file to ingest (PDF, DOCX, TXT, etc.)",
                  "value": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/pipeline/ingest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pipeline",
                "ingest"
              ]
            },
            "description": "Ingest a document into the processing pipeline. Upload a file via multipart/form-data. The server parses the document, splits it into chunks, generates vector embeddings, and stores them for semantic retrieval. Use the search endpoints to query ingested content."
          },
          "response": []
        },
        {
          "name": "Search Documents (POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What are the key findings in the report?\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/pipeline/search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pipeline",
                "search"
              ]
            },
            "description": "Perform a semantic search over all ingested documents (POST variant). Provide a natural language query in the request body. Returns ranked document chunks most relevant to the query, along with similarity scores and source metadata."
          },
          "response": []
        },
        {
          "name": "Search Documents (GET)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/pipeline/search?query=your search query here",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pipeline",
                "search"
              ],
              "query": [
                {
                  "key": "query",
                  "value": "your search query here",
                  "description": "Natural language search query to run against ingested documents."
                }
              ]
            },
            "description": "Perform a semantic search over all ingested documents (GET variant). Pass the search query as a URL query parameter named `query`. Returns ranked document chunks most relevant to the query. Useful for quick browser-based or link-based searches."
          },
          "response": []
        }
      ],
      "description": "Document ingestion and semantic search pipeline. Ingest documents to embed and index them, then search across ingested content using natural language queries. All routes are protected."
    },
